# ============================================================
# Espaço Terapêutico — Environment Variables
# EASYPANEL: Cole estas variáveis na UI de configuração
# ============================================================

# OBRIGATÓRIO
JWT_SECRET=

# Domínio
CORS_ORIGIN=https://seudominio.com.br

# ── Stripe (pagamentos) ─────────────────────────────────────
# Pode ser configurado pelo Admin Panel OU aqui
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI (opcional — configura pelo Admin Panel) ───────────────
AI_API_KEY=
AI_API_URL=https://api.laozhang.ai/v1/chat/completions
AI_MODEL=deepseek-v3

# ── Push (opcional) ──────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:contato@seudominio.com.br

# ── Jitsi (teleconsulta) ────────────────────────────────────
VITE_JITSI_DOMAIN=meet.jit.si
